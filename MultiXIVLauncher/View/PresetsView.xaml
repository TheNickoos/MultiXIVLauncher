<UserControl x:Class="MultiXIVLauncher.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Background="{StaticResource BgGradient}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,0,12">
            <TextBlock Text="Liste des presets"
                 Style="{StaticResource TitleText}"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"/>

            <Button x:Name="BtnDownloadPreset"
              Content="⬇ Télécharger un preset"
              Height="34"
              Margin="0,0,8,0"
              Style="{StaticResource OutlineButton}"/>

            <Button x:Name="BtnAddPreset"
              Content="+ Ajouter un preset"
              Height="34"
              Margin="0,0,8,0"
              Style="{StaticResource RoundedButton}"
              Click="BtnAddPreset_Click"/>

            <Button x:Name="BtnValidate"
              Content="✔ Valider"
              Height="34"
              Visibility="Collapsed"
              Margin="0,0,8,0"
              Style="{StaticResource RoundedButton}"
              Click="BtnValidate_Click"/>

            <TextBox x:Name="TxtPresetName"
               Width="200"
               Height="32"
               Visibility="Collapsed"
               VerticalAlignment="Center"
               Background="#1E1E2A"
               Foreground="{StaticResource ClrTextPrimary}"
               BorderBrush="{StaticResource ClrAccent}"
               BorderThickness="1"
               Padding="6,2"
               Margin="0,0,8,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PresetListPanel">

                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                       Text="Ultimate Bard Preset"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource ClrTextPrimary}"
                       VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                            <Button Content="Modifier"
                      Height="30"
                      Margin="0,0,8,0"
                      Style="{StaticResource OutlineButton}"/>
                            <Button Content="Supprimer"
                      Height="30"
                      Style="{StaticResource OutlineButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
