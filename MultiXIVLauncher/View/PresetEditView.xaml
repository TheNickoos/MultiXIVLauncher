<UserControl x:Class="MultiXIVLauncher.Views.PresetEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

  <Grid Background="{StaticResource BgGradient}" Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Orientation="Vertical" Margin="0,0,0,16">
      <TextBlock Text="Édition du preset"
                 Style="{StaticResource TitleText}"
                 Margin="0,0,0,8"/>
      <TextBox x:Name="TxtPresetName"
               Width="300"
               Height="34"
               Background="#1E1E2A"
               Foreground="{StaticResource ClrTextPrimary}"
               BorderBrush="{StaticResource ClrAccent}"
               BorderThickness="1"
               Padding="6,2"
               Text="Ultimate Bard Preset"/>
    </StackPanel>

    <StackPanel Grid.Row="1" VerticalAlignment="Top">
      <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Copier la configuration d’un personnage"
                     FontWeight="SemiBold" FontSize="16"
                     Foreground="{StaticResource ClrTextPrimary}" Margin="0,0,0,8"/>
          <TextBlock Text="Importe directement les plugins et paramètres d’un de tes personnages dans ce preset."
                     Style="{StaticResource BodyText}" Opacity="0.8"
                     TextWrapping="Wrap" Margin="0,0,0,12"/>
          <Button Content="📋 Copier depuis un personnage"
                  Height="36" Width="260"
                  Style="{StaticResource RoundedButton}"
                  Click="CopyFromCharacter_Click"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}" Padding="16">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Explorer le répertoire du preset"
                     FontWeight="SemiBold" FontSize="16"
                     Foreground="{StaticResource ClrTextPrimary}" Margin="0,0,0,8"/>
          <TextBlock Text="Accède rapidement au dossier contenant tous les fichiers liés à ce preset."
                     Style="{StaticResource BodyText}" Opacity="0.8"
                     TextWrapping="Wrap" Margin="0,0,0,12"/>
          <Button Content="📁 Ouvrir le dossier"
                  Height="36" Width="260"
                  Style="{StaticResource RoundedButton}"
                  Click="OpenPresetFolder_Click"/>
        </StackPanel>
      </Border>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="💾 Sauvegarder"
              Width="160"
              Height="34"
              Margin="0,0,8,0"
              Style="{StaticResource RoundedButton}"
              Click="SavePreset_Click"/>
      <Button Content="↩ Retour"
              Width="120"
              Height="34"
              Style="{StaticResource OutlineButton}"
              Click="GoBack_Click"/>
    </StackPanel>
  </Grid>
</UserControl>
